---
import '../styles/global.css'

const { title = '2nd Brain Public', description = 'Curated visual knowledge notes.' } = Astro.props
const base = import.meta.env.BASE_URL
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <a class="brand" href={base}>2nd Brain Public</a>
        <nav class="nav" aria-label="Primary navigation">
          <a href={`${base}categories/ai/`}>AI</a>
          <a href={`${base}categories/investing/`}>Investing</a>
          <a href={`${base}map/`}>Knowledge Map</a>
          <a href={`${base}notes/`}>Notes</a>
        </nav>
      </header>
      <slot />
      <footer class="footer">
        Curated public notes. Educational and informational material only.
      </footer>
    </div>
  </body>
</html>
