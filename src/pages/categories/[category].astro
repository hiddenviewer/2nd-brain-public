---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import NoteCard from '../../components/NoteCard.astro'

const labels = {
  ai: 'AI 에이전트',
  apple: 'Apple',
  investing: '한국 주식',
  language: '언어',
  travel: '여행',
}

export async function getStaticPaths() {
  const labels = {
    ai: 'AI 에이전트',
    apple: 'Apple',
    investing: '한국 주식',
    language: '언어',
    travel: '여행',
  }

  return Object.keys(labels).map((category) => ({ params: { category } }))
}

const { category } = Astro.params
const notes = await getCollection('notes', ({ data }) => data.status === 'published' && data.category === category)
const languageArtifacts = [
  {
    title: 'Workplace Buddy English Phrase Guide',
    description: '외국인 동료나 방문자를 도울 때 바로 쓸 수 있는 상황별 영어 표현 가이드입니다.',
    href: '/english/workplace-buddy-english/',
    tags: ['english', 'workplace', 'speaking'],
  },
]
const artifacts = category === 'language' ? languageArtifacts : []
const base = import.meta.env.BASE_URL
const basePath = base.endsWith('/') ? base : `${base}/`
const withBase = (href) => `${basePath}${href.replace(/^\//, '')}`
---

<BaseLayout title={`${labels[category]} | 2nd Brain Public`}>
  <main class="container section">
    <div class="section-header">
      <div>
        <p class="eyebrow">카테고리</p>
        <h1>{labels[category]}</h1>
      </div>
      <p>
        {notes.length > 0
          ? '이 카테고리에 공개된 노트입니다.'
          : '앞으로 공개 노트를 추가할 예정인 카테고리입니다.'}
      </p>
    </div>
    {artifacts.length > 0 && (
      <section class="resource-section">
        <h2>영어 학습 자료</h2>
        <div class="grid">
          {artifacts.map((artifact) => (
            <a class="note-card resource-card" href={withBase(artifact.href)}>
              <p class="eyebrow">Interactive HTML</p>
              <h3>{artifact.title}</h3>
              <p>{artifact.description}</p>
              <div class="tag-row">
                {artifact.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {notes.length > 0 ? (
      <div class="grid">
        {notes.map((note) => <NoteCard note={note} />)}
      </div>
    ) : artifacts.length === 0 ? (
      <div class="callout" style="padding: 24px;">아직 공개된 노트가 없습니다.</div>
    ) : null}
  </main>
</BaseLayout>
