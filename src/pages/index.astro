---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import NoteCard from '../components/NoteCard.astro'
import KnowledgeGraph from '../components/KnowledgeGraph.astro'

const notes = await getCollection('notes', ({ data }) => data.status === 'published')
const featured = notes.filter((note) => note.data.featured)
const base = import.meta.env.BASE_URL
const basePath = base.endsWith('/') ? base : `${base}/`
const withBase = (href) => `${basePath}${href.replace(/^\//, '')}`
---

<BaseLayout title="2nd Brain Public" description="개인 세컨드 브레인에서 선별한 공개용 시각 지식 노트입니다.">
  <main>
    <section class="container hero">
      <div>
        <p class="eyebrow">공개 지식 노트</p>
        <h1>선별된 지식을 보기 좋은 노트로 재구성합니다.</h1>
        <p class="lead">
          AI 에이전트, Apple 기술, 한국 주식 리서치, 언어 학습, 여행처럼 계속 확장될 주제를
          웹에서 탐색하기 쉬운 시각 노트와 지식 지도로 정리합니다.
        </p>
      </div>
      <aside class="hero-panel">
        <h3>공개 방식</h3>
        <p>
          private 위키를 그대로 노출하지 않습니다. 공개할 가치가 있는 내용만 선별하고,
          원천 자료와 내부 메모를 바탕으로 설명형 노트나 슬라이드형 페이지로 다시 작성합니다.
        </p>
        <div class="metric-grid">
          <div class="metric">
            <strong>{notes.length}</strong>
            <span>공개 노트</span>
          </div>
          <div class="metric">
            <strong>5</strong>
            <span>확장 예정 영역</span>
          </div>
        </div>
      </aside>
    </section>

    <section class="container section">
      <div class="section-header">
        <div>
          <p class="eyebrow">탐색</p>
          <h2>카테고리</h2>
        </div>
        <p>처음에는 AI와 한국 주식 중심으로 시작하고, 이후 Apple, 영어, 일본어, 여행까지 같은 구조로 확장합니다.</p>
      </div>
      <div class="category-strip">
        <a class="category-pill" href={withBase('/categories/ai/')}><strong>AI</strong><span>에이전트, 도구, 워크플로</span></a>
        <a class="category-pill" href={withBase('/categories/investing/')}><strong>한국 주식</strong><span>리서치 프로세스와 시장 노트</span></a>
        <a class="category-pill" href={withBase('/categories/apple/')}><strong>Apple</strong><span>공개 예정</span></a>
        <a class="category-pill" href={withBase('/categories/language/')}><strong>언어</strong><span>영어, 일본어 학습 노트</span></a>
        <a class="category-pill" href={withBase('/categories/travel/')}><strong>여행</strong><span>도시, 일정, 경험 정리</span></a>
      </div>
    </section>

    <section class="container section">
      <div class="section-header">
        <div>
          <p class="eyebrow">추천</p>
          <h2>시각 노트</h2>
        </div>
        <p>원본 요약을 그대로 보여주지 않고, 맥락과 구조를 갖춘 공개용 설명 노트로 재작성합니다.</p>
      </div>
      <div class="grid">
        {featured.map((note) => <NoteCard note={note} />)}
      </div>
    </section>

    <section class="container section">
      <div class="section-header">
        <div>
          <p class="eyebrow">지도</p>
          <h2>지식 지도</h2>
        </div>
        <p>공개 노트 사이의 연결을 먼저 작게 보여주고, 이후 graphify 결과를 바탕으로 자동 생성할 수 있게 확장합니다.</p>
      </div>
      <KnowledgeGraph />
    </section>
  </main>
</BaseLayout>
