---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => data.status === 'published')
  return notes.map((note) => ({ params: { slug: note.slug }, props: { note } }))
}

const { note } = Astro.props
const { Content } = await render(note)
const { title, description, category, tags, updated, confidence, sources } = note.data
const categoryLabels = {
  ai: 'AI 에이전트',
  apple: 'Apple',
  investing: '한국 주식',
  language: '언어',
  travel: '여행',
}
---

<BaseLayout title={`${title} | 2nd Brain Public`} description={description}>
  <main class="container note-layout">
    <article class="note-body">
      <p class="eyebrow">{categoryLabels[category] ?? category}</p>
      <h1>{title}</h1>
      <p class="lead">{description}</p>
      <Content />
    </article>
    <aside class="aside">
      <h3>노트 정보</h3>
      <p><strong>업데이트:</strong> {updated.toISOString().slice(0, 10)}</p>
      <p><strong>신뢰도:</strong> {confidence}</p>
      <div class="tag-row">
        {tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
      {sources.length > 0 && (
        <>
          <h3 style="margin-top: 24px;">출처</h3>
          <ul>
            {sources.map((source) => (
              <li>
                {source.url ? <a href={source.url}>{source.label}</a> : source.label}
              </li>
            ))}
          </ul>
        </>
      )}
    </aside>
  </main>
</BaseLayout>
