---
import BaseLayout from '../layouts/BaseLayout.astro'
import links from '../data/links.json'

const categories = [
  { id: 'ai', label: 'AI 에이전트' },
  { id: 'apple', label: 'Apple' },
  { id: 'investing', label: '한국 주식' },
  { id: 'language', label: '언어' },
  { id: 'travel', label: '여행' },
  { id: 'general', label: '기타' },
]

const statusLabels = {
  public: '공개',
  pending: '대기',
  review: '검토 필요',
  private: '비공개',
  dead: '접근 불가',
}

const grouped = categories
  .map((category) => ({
    ...category,
    links: links.filter((link) => link.category === category.id),
  }))
  .filter((category) => category.links.length > 0)

const publicCount = links.filter((link) => link.status === 'public').length
const pendingCount = links.filter((link) => link.status === 'pending').length
const reviewCount = links.filter((link) => link.status === 'review').length
const companyCount = new Set(links.flatMap((link) => (link.companies || []).map((company) => company.id))).size
const base = import.meta.env.BASE_URL
const basePath = base.endsWith('/') ? base : `${base}/`
const withBase = (href) => `${basePath}${href.replace(/^\//, '')}`
---

<BaseLayout title="링크 인덱스 | 2nd Brain Public">
  <main class="container section">
    <div class="section-header">
      <div>
        <p class="eyebrow">링크</p>
        <h1>링크 인덱스</h1>
      </div>
      <p>
        private 2nd-brain의 source note와 inbox metadata에서 추출한 공개용 링크 목록입니다.
        ingest 전 자료는 대기 상태로 표시하고, 정식 source note가 생기면 자동으로 공개 또는 검토 필요 상태로 정리합니다.
      </p>
    </div>

    <div class="metric-grid link-summary">
      <div class="metric">
        <strong>{links.length}</strong>
        <span>전체 링크</span>
      </div>
      <div class="metric">
        <strong>{publicCount}</strong>
        <span>공개 링크</span>
      </div>
      <div class="metric">
        <strong>{reviewCount}</strong>
        <span>검토 필요</span>
      </div>
      <div class="metric">
        <strong>{companyCount}</strong>
        <span>감지된 기업</span>
      </div>
    </div>

    <nav class="link-jump" aria-label="Link category shortcuts">
      <a href={withBase('/companies/')}>기업별 보기 <span>{companyCount}</span></a>
      {grouped.map((group) => (
        <a href={`#${group.id}`}>{group.label} <span>{group.links.length}</span></a>
      ))}
    </nav>

    <div class="link-groups">
      {grouped.map((group) => (
        <section class="link-group" id={group.id}>
          <div class="section-header compact">
            <div>
              <p class="eyebrow">카테고리</p>
              <h2>{group.label}</h2>
            </div>
            <p>{group.links.length}개 링크</p>
          </div>
          <div class="link-list">
            {group.links.map((link) => (
              <article class="link-item">
                <div>
                  <div class="link-meta">
                    <span class:list={['status-badge', link.status]}>{statusLabels[link.status] ?? link.status}</span>
                    {link.updated && <span>{link.updated}</span>}
                    <span>{link.sourceNote}</span>
                  </div>
                  <h3><a href={link.url} target="_blank" rel="noreferrer">{link.title}</a></h3>
                  {link.description && <p>{link.description}</p>}
                  <div class="tag-row">
                    {link.tags.slice(0, 6).map((tag) => <span class="tag">{tag}</span>)}
                  </div>
                </div>
                <a class="external-link" href={link.url} target="_blank" rel="noreferrer">열기</a>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </main>
</BaseLayout>
