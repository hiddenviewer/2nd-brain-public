---
import BaseLayout from '../../layouts/BaseLayout.astro'
import links from '../../data/links.json'
import companies from '../../data/companies.json'

const statusLabels = {
  public: '공개',
  pending: '대기',
  review: '검토 필요',
  private: '비공개',
  dead: '접근 불가',
}

export async function getStaticPaths() {
  const companyMap = new Map()
  for (const company of companies) {
    companyMap.set(company.id, company)
  }
  for (const link of links) {
    for (const company of link.companies || []) {
      if (!companyMap.has(company.id)) {
        companyMap.set(company.id, company)
      }
    }
  }
  return Array.from(companyMap.values()).map((company) => ({
    params: { company: company.id },
    props: { company },
  }))
}

const { company } = Astro.props
const companyLinks = links
  .filter((link) => (link.companies || []).some((item) => item.id === company.id))
  .sort((a, b) => (b.updated || '').localeCompare(a.updated || '') || a.title.localeCompare(b.title, 'ko'))

const publicCount = companyLinks.filter((link) => link.status === 'public').length
const pendingCount = companyLinks.filter((link) => link.status === 'pending').length
const reviewCount = companyLinks.filter((link) => link.status === 'review').length
const tags = Array.from(new Set(companyLinks.flatMap((link) => link.tags || []))).slice(0, 10)
const annualFinancials = company.annualFinancials
const quarterlyFinancials = company.quarterlyFinancials

const parseAmount = (value) => {
  const text = String(value || '').replace(/\(계산\)/g, '').replace(/,/g, '').trim()
  const match = text.match(/-?\d+(?:\.\d+)?/)
  return match ? Number(match[0]) : null
}

const parsePercent = (value) => {
  const match = String(value || '').replace(/,/g, '').match(/-?\d+(?:\.\d+)?/)
  return match ? Number(match[0]) : null
}

const getCell = (table, row, name) => {
  if (!table || !row) return ''
  const index = table.headers.findIndex((header) => header === name)
  return index >= 0 ? row[index] : ''
}

const tableToSeries = (table) => {
  if (!table) return []
  const indexOf = (name) => table.headers.findIndex((header) => header === name)
  const periodIndex = 0
  const revenueIndex = indexOf('매출')
  const operatingIncomeIndex = indexOf('영업이익')
  const netIncomeIndex = indexOf('순이익')
  const marginIndex = indexOf('영업이익율')
  const expenseIndex = indexOf('영업비용')

  return table.rows
    .map((row) => ({
      period: row[periodIndex],
      revenue: parseAmount(row[revenueIndex]),
      revenueLabel: row[revenueIndex],
      operatingIncome: parseAmount(row[operatingIncomeIndex]),
      operatingIncomeLabel: row[operatingIncomeIndex],
      netIncome: parseAmount(row[netIncomeIndex]),
      netIncomeLabel: row[netIncomeIndex],
      operatingExpense: parseAmount(row[expenseIndex]),
      operatingExpenseLabel: row[expenseIndex],
      operatingMargin: parsePercent(row[marginIndex]),
      operatingMarginLabel: row[marginIndex],
    }))
    .filter((row) => row.period)
}

const buildChart = (rows) => {
  if (!rows.length) return null
  const metrics = [
    { key: 'revenue', label: '매출', color: '#126b64' },
    { key: 'operatingIncome', label: '영업이익', color: '#395a8f' },
    { key: 'netIncome', label: '순이익', color: '#a34727' },
    { key: 'operatingExpense', label: '영업비용', color: '#7a6f57' },
  ]
  const width = 860
  const height = 360
  const margin = { top: 22, right: 64, bottom: 74, left: 72 }
  const plotWidth = width - margin.left - margin.right
  const plotHeight = height - margin.top - margin.bottom
  const amountValues = rows.flatMap((row) => metrics.map((metric) => row[metric.key])).filter((value) => value !== null)
  const marginValues = rows.map((row) => row.operatingMargin).filter((value) => value !== null)
  const amountMin = Math.min(0, ...amountValues)
  const amountMax = Math.max(0, ...amountValues)
  const marginMin = Math.min(0, ...marginValues)
  const marginMax = Math.max(0, ...marginValues)
  const amountSpan = amountMax - amountMin || 1
  const marginSpan = marginMax - marginMin || 1
  const yAmount = (value) => margin.top + ((amountMax - value) / amountSpan) * plotHeight
  const yMargin = (value) => margin.top + ((marginMax - value) / marginSpan) * plotHeight
  const groupWidth = plotWidth / rows.length
  const barWidth = Math.max(8, Math.min(18, groupWidth / 7))
  const zeroY = yAmount(0)
  const bars = rows.flatMap((row, rowIndex) =>
    metrics.map((metric, metricIndex) => {
      const value = row[metric.key]
      if (value === null) return null
      const displayValue = row[`${metric.key}Label`] || `${value.toLocaleString('ko-KR')}억원`
      const groupStart = margin.left + rowIndex * groupWidth
      const x = groupStart + groupWidth / 2 - (metrics.length * barWidth) / 2 + metricIndex * barWidth
      const y = Math.min(yAmount(value), zeroY)
      const h = Math.max(1, Math.abs(zeroY - yAmount(value)))
      return { ...metric, value, displayValue, period: row.period, x, y, height: h }
    }),
  ).filter(Boolean)
  const linePoints = rows
    .map((row, rowIndex) => {
      if (row.operatingMargin === null) return null
      const x = margin.left + rowIndex * groupWidth + groupWidth / 2
      const y = yMargin(row.operatingMargin)
      return {
        x,
        y,
        value: row.operatingMargin,
        displayValue: row.operatingMarginLabel || `${row.operatingMargin.toFixed(1)}%`,
        period: row.period,
      }
    })
    .filter(Boolean)
  const xLabels = rows.map((row, rowIndex) => ({
    label: row.period,
    x: margin.left + rowIndex * groupWidth + groupWidth / 2,
    y: height - 38,
  }))
  const amountTicks = [amountMin, (amountMin + amountMax) / 2, amountMax].map((value) => ({
    value,
    label: `${Math.round(value).toLocaleString('ko-KR')}억`,
    y: yAmount(value),
  }))
  const marginTicks = [marginMin, (marginMin + marginMax) / 2, marginMax].map((value) => ({
    value,
    label: `${value.toFixed(1)}%`,
    y: yMargin(value),
  }))
  return {
    width,
    height,
    margin,
    plotWidth,
    plotHeight,
    metrics,
    bars,
    linePoints,
    linePath: linePoints.map((point) => `${point.x},${point.y}`).join(' '),
    xLabels,
    amountTicks,
    marginTicks,
    zeroY,
  }
}

const annualSeries = tableToSeries(annualFinancials)
const quarterlySeries = tableToSeries(quarterlyFinancials)
const annualChart = buildChart(annualSeries)
const quarterlyChart = buildChart(quarterlySeries)
const hasFinancialDashboard = annualFinancials || quarterlyFinancials
const latestAnnualRow = annualFinancials?.rows?.at(-1)
const latestQuarterlyRow = quarterlyFinancials?.rows?.at(-1)
const summaryMetrics = [
  latestAnnualRow && {
    label: `${latestAnnualRow[0]} 매출`,
    value: getCell(annualFinancials, latestAnnualRow, '매출'),
  },
  latestAnnualRow && {
    label: `${latestAnnualRow[0]} 영업이익`,
    value: getCell(annualFinancials, latestAnnualRow, '영업이익'),
  },
  latestAnnualRow && {
    label: `${latestAnnualRow[0]} 영업이익률`,
    value: getCell(annualFinancials, latestAnnualRow, '영업이익율'),
  },
  latestQuarterlyRow && {
    label: `${latestQuarterlyRow[0]} 영업이익률`,
    value: getCell(quarterlyFinancials, latestQuarterlyRow, '영업이익율'),
  },
].filter(Boolean)
---

<BaseLayout title={`${company.label} 링크 | 2nd Brain Public`}>
  <main class="container section">
    <div class="section-header">
      <div>
        <p class="eyebrow">{company.ticker || company.sector || 'Company'}</p>
        <h1>{company.label}</h1>
      </div>
      <p>이 기업과 연결된 공개 링크, 검토 링크, ingest 대기 링크를 최신순으로 모았습니다.</p>
    </div>

    <div class="company-overview">
      <section class="company-profile">
        <div class="company-profile-header">
          <div>
            <p class="eyebrow">Company Snapshot</p>
            <h2>{company.label}</h2>
          </div>
          {company.naverFinanceUrl && (
            <a class="button secondary company-action" href={company.naverFinanceUrl} target="_blank" rel="noreferrer">
              네이버 금융
            </a>
          )}
        </div>
        <div class="company-profile-grid">
          <dl>
            <div>
              <dt>종목코드</dt>
              <dd>{company.ticker || '확인 필요'}</dd>
            </div>
            <div>
              <dt>섹터</dt>
              <dd>{company.sector || '확인 필요'}</dd>
            </div>
            <div>
              <dt>DART 코드</dt>
              <dd>{company.dartCorpCode || '확인 필요'}</dd>
            </div>
            <div>
              <dt>업데이트</dt>
              <dd>{company.updated || '확인 필요'}</dd>
            </div>
          </dl>
          {summaryMetrics.length > 0 && (
            <div class="company-metric-strip">
              {summaryMetrics.map((metric) => (
                <div>
                  <strong>{metric.value}</strong>
                  <span>{metric.label}</span>
                </div>
              ))}
            </div>
          )}
        </div>
        {company.companyInfo?.length > 0 && (
          <ul class="company-info-list">
            {company.companyInfo.slice(0, 6).map((item) => <li>{item}</li>)}
          </ul>
        )}
      </section>

      {hasFinancialDashboard && (
        <section class="financial-section">
          <h2>재무 요약</h2>
          <div class="financial-dashboard">
            <input id={`financial-annual-${company.id}`} type="radio" name={`financial-view-${company.id}`} checked={Boolean(annualFinancials)} />
            <input id={`financial-quarterly-${company.id}`} type="radio" name={`financial-view-${company.id}`} checked={!annualFinancials && Boolean(quarterlyFinancials)} />
            <div class="financial-tabs">
              {annualFinancials && <label for={`financial-annual-${company.id}`}>연간</label>}
              {quarterlyFinancials && <label for={`financial-quarterly-${company.id}`}>분기</label>}
            </div>

            {annualFinancials && (
              <div class="financial-panel annual-panel">
                {annualChart && (
                  <div class="financial-chart">
                    <div class="chart-header">
                      <h3>연간 추이</h3>
                      <div class="chart-legend">
                        {annualChart.metrics.map((metric) => <span style={`--legend-color: ${metric.color}`}>{metric.label}</span>)}
                        <span class="line-legend">영업이익률</span>
                      </div>
                    </div>
                    <div class="chart-scroll">
                      <svg viewBox={`0 0 ${annualChart.width} ${annualChart.height}`} role="img" aria-label={`${company.label} 연간 재무 그래프`}>
                        <rect x={annualChart.margin.left} y={annualChart.margin.top} width={annualChart.plotWidth} height={annualChart.plotHeight} class="chart-plot" />
                        {annualChart.amountTicks.map((tick) => (
                          <>
                            <line x1={annualChart.margin.left} x2={annualChart.width - annualChart.margin.right} y1={tick.y} y2={tick.y} class="chart-gridline" />
                            <text x={annualChart.margin.left - 10} y={tick.y + 4} class="chart-axis left">{tick.label}</text>
                          </>
                        ))}
                        {annualChart.marginTicks.map((tick) => (
                          <text x={annualChart.width - annualChart.margin.right + 10} y={tick.y + 4} class="chart-axis right">{tick.label}</text>
                        ))}
                        <line x1={annualChart.margin.left} x2={annualChart.width - annualChart.margin.right} y1={annualChart.zeroY} y2={annualChart.zeroY} class="chart-zero" />
                        {annualChart.bars.map((bar) => (
                          <rect class="chart-data-point" tabindex="0" data-tooltip={`${bar.period} ${bar.label}: ${bar.displayValue}`} x={bar.x} y={bar.y} width="14" height={bar.height} fill={bar.color} rx="2" aria-label={`${bar.period} ${bar.label} ${bar.displayValue}`}>
                            <title>{`${bar.period} ${bar.label}: ${bar.displayValue}`}</title>
                          </rect>
                        ))}
                        {annualChart.linePoints.length > 1 && <polyline points={annualChart.linePath} class="chart-margin-line" />}
                        {annualChart.linePoints.map((point) => (
                          <circle class="chart-data-point chart-margin-dot" tabindex="0" data-tooltip={`${point.period} 영업이익률: ${point.displayValue}`} cx={point.x} cy={point.y} r="4" aria-label={`${point.period} 영업이익률 ${point.displayValue}`}>
                            <title>{`${point.period} 영업이익률: ${point.displayValue}`}</title>
                          </circle>
                        ))}
                        {annualChart.xLabels.map((label) => (
                          <text x={label.x} y={label.y} class="chart-x-label" transform={`rotate(-35 ${label.x} ${label.y})`}>{label.label}</text>
                        ))}
                      </svg>
                    </div>
                    <div class="chart-tooltip" aria-live="polite"></div>
                  </div>
                )}
                <div class="financial-table-block">
                  <h3>전체 연간 재무</h3>
                  <div class="table-scroll">
                    <table>
                      <thead>
                        <tr>{annualFinancials.headers.map((header) => <th>{header}</th>)}</tr>
                      </thead>
                      <tbody>
                        {annualFinancials.rows.map((row) => (
                          <tr>{row.map((cell) => <td>{cell}</td>)}</tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            )}

            {quarterlyFinancials && (
              <div class="financial-panel quarterly-panel">
                {quarterlyChart && (
                  <div class="financial-chart">
                    <div class="chart-header">
                      <h3>분기 추이</h3>
                      <div class="chart-legend">
                        {quarterlyChart.metrics.map((metric) => <span style={`--legend-color: ${metric.color}`}>{metric.label}</span>)}
                        <span class="line-legend">영업이익률</span>
                      </div>
                    </div>
                    <div class="chart-scroll">
                      <svg viewBox={`0 0 ${quarterlyChart.width} ${quarterlyChart.height}`} role="img" aria-label={`${company.label} 분기 재무 그래프`}>
                        <rect x={quarterlyChart.margin.left} y={quarterlyChart.margin.top} width={quarterlyChart.plotWidth} height={quarterlyChart.plotHeight} class="chart-plot" />
                        {quarterlyChart.amountTicks.map((tick) => (
                          <>
                            <line x1={quarterlyChart.margin.left} x2={quarterlyChart.width - quarterlyChart.margin.right} y1={tick.y} y2={tick.y} class="chart-gridline" />
                            <text x={quarterlyChart.margin.left - 10} y={tick.y + 4} class="chart-axis left">{tick.label}</text>
                          </>
                        ))}
                        {quarterlyChart.marginTicks.map((tick) => (
                          <text x={quarterlyChart.width - quarterlyChart.margin.right + 10} y={tick.y + 4} class="chart-axis right">{tick.label}</text>
                        ))}
                        <line x1={quarterlyChart.margin.left} x2={quarterlyChart.width - quarterlyChart.margin.right} y1={quarterlyChart.zeroY} y2={quarterlyChart.zeroY} class="chart-zero" />
                        {quarterlyChart.bars.map((bar) => (
                          <rect class="chart-data-point" tabindex="0" data-tooltip={`${bar.period} ${bar.label}: ${bar.displayValue}`} x={bar.x} y={bar.y} width="14" height={bar.height} fill={bar.color} rx="2" aria-label={`${bar.period} ${bar.label} ${bar.displayValue}`}>
                            <title>{`${bar.period} ${bar.label}: ${bar.displayValue}`}</title>
                          </rect>
                        ))}
                        {quarterlyChart.linePoints.length > 1 && <polyline points={quarterlyChart.linePath} class="chart-margin-line" />}
                        {quarterlyChart.linePoints.map((point) => (
                          <circle class="chart-data-point chart-margin-dot" tabindex="0" data-tooltip={`${point.period} 영업이익률: ${point.displayValue}`} cx={point.x} cy={point.y} r="4" aria-label={`${point.period} 영업이익률 ${point.displayValue}`}>
                            <title>{`${point.period} 영업이익률: ${point.displayValue}`}</title>
                          </circle>
                        ))}
                        {quarterlyChart.xLabels.map((label) => (
                          <text x={label.x} y={label.y} class="chart-x-label" transform={`rotate(-35 ${label.x} ${label.y})`}>{label.label}</text>
                        ))}
                      </svg>
                    </div>
                    <div class="chart-tooltip" aria-live="polite"></div>
                  </div>
                )}
                <div class="financial-table-block">
                  <h3>전체 분기 재무</h3>
                  <div class="table-scroll">
                    <table>
                      <thead>
                        <tr>{quarterlyFinancials.headers.map((header) => <th>{header}</th>)}</tr>
                      </thead>
                      <tbody>
                        {quarterlyFinancials.rows.map((row) => (
                          <tr>{row.map((cell) => <td>{cell}</td>)}</tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            )}
          </div>
        </section>
      )}
    </div>

    <div class="metric-grid link-summary">
      <div class="metric">
        <strong>{companyLinks.length}</strong>
        <span>전체 링크</span>
      </div>
      <div class="metric">
        <strong>{publicCount}</strong>
        <span>공개 링크</span>
      </div>
      <div class="metric">
        <strong>{reviewCount}</strong>
        <span>검토 필요</span>
      </div>
      <div class="metric">
        <strong>{pendingCount}</strong>
        <span>ingest 대기</span>
      </div>
    </div>

    {tags.length > 0 && (
      <div class="tag-row company-tags">
        {tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    )}

    <div class="link-list">
      {companyLinks.map((link) => (
        <article class="link-item">
          <div>
            <div class="link-meta">
              <span class:list={['status-badge', link.status]}>{statusLabels[link.status] ?? link.status}</span>
              {link.updated && <span>{link.updated}</span>}
              <span>{link.sourceNote}</span>
            </div>
            <h3><a href={link.url} target="_blank" rel="noreferrer">{link.title}</a></h3>
            {link.description && <p>{link.description}</p>}
            <div class="tag-row">
              {(link.tags || []).slice(0, 6).map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </div>
          <a class="external-link" href={link.url} target="_blank" rel="noreferrer">열기</a>
        </article>
      ))}
    </div>
  </main>

  <script is:inline>
    const showChartTooltip = (target, event) => {
      const chart = target.closest('.financial-chart')
      const tooltip = chart?.querySelector('.chart-tooltip')
      const text = target.dataset.tooltip
      if (!chart || !tooltip || !text) return

      tooltip.textContent = text
      tooltip.classList.add('visible')

      const chartRect = chart.getBoundingClientRect()
      const targetRect = target.getBoundingClientRect()
      const sourceX = event?.clientX ?? targetRect.left + targetRect.width / 2
      const sourceY = event?.clientY ?? targetRect.top
      const x = Math.min(Math.max(sourceX - chartRect.left + 12, 12), chartRect.width - tooltip.offsetWidth - 12)
      const y = Math.max(sourceY - chartRect.top - 36, 12)

      tooltip.style.left = `${x}px`
      tooltip.style.top = `${y}px`
    }

    document.querySelectorAll('.chart-data-point').forEach((target) => {
      target.addEventListener('mouseenter', (event) => showChartTooltip(target, event))
      target.addEventListener('mousemove', (event) => showChartTooltip(target, event))
      target.addEventListener('focus', () => showChartTooltip(target))
      target.addEventListener('mouseleave', () => {
        target.closest('.financial-chart')?.querySelector('.chart-tooltip')?.classList.remove('visible')
      })
      target.addEventListener('blur', () => {
        target.closest('.financial-chart')?.querySelector('.chart-tooltip')?.classList.remove('visible')
      })
    })
  </script>
</BaseLayout>
